{
  "name": "indian-pincode-utils",
  "version": "1.0.0",
  "description": "Fast Indian pincode lookup with geospatial utilities",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "files": [
    "dist",
    "data"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/indian-pincode"
  },
  "keywords": [
    "pincode",
    "india",
    "indian-pincode",
    "postal-code",
    "pin-code",
    "india-post",
    "geo",
    "geolocation",
    "distance",
    "logistics",
    "delivery",
    "zipcode-india",
    "postal-data"
  ],
  "license": "MIT",
  "scripts": {
    "generate:data": "node ./scripts/csv-to-json.js",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:fix-esm": "node ./scripts/fix-esm-imports.js",
    "build:copy-data": "node -e \"const fs=require('fs');fs.rmSync('dist/data',{recursive:true,force:true});fs.cpSync('data','dist/data',{recursive:true});\"",
    "build": "npm run build:cjs && npm run build:esm && npm run build:fix-esm && npm run build:copy-data",
    "test": "node ./scripts/smoke-test.js",
    "benchmark": "node ./scripts/benchmark.js"
  },
  "dependencies": {
    "ngeohash": "^0.6.3"
  },
  "devDependencies": {
    "@types/ngeohash": "^0.6.8",
    "@types/node": "^20.11.0",
    "csv-parser": "^3.2.0",
    "typescript": "^5.4.0"
  }
}

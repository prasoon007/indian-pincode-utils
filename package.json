{
  "name": "indian-pincode-utils",
  "version": "1.0.0",
  "description": "Fast Indian pincode lookup with geospatial utilities",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "files": [
    "dist",
    "data"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/indian-pincode"
  },
  "keywords": [
    "pincode",
    "india",
    "indian-pincode",
    "postal-code",
    "pin-code",
    "india-post",
    "geo",
    "geolocation",
    "distance",
    "logistics",
    "delivery",
    "zipcode-india",
    "postal-data"
  ],
  "license": "MIT",
  "scripts": {
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build": "npm run build:cjs && npm run build:esm"
  },
  "dependencies": {
    "ngeohash": "^0.6.3"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
